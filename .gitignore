*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
uv.lock.bak

# IDE / editor
.vscode/
.idea/
*.swp
*~

# Logs & runtime
logs/
*.log
xrun_forensics_*.json
tests/latency_harness/baseline.json
tests/soak_harness/results/

# Artifacts produced by harnesses
tests/accuracy_harness/results/
tests/perceptual/listening_test_v0/data/

